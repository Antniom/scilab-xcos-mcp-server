  "xmlExample": "<Product id=\"b1\" parent=\"0:2:0\" interfaceFunctionName=\"PRODUCT\" blockType=\"c\" dependsOnU=\"1\" dependsOnT=\"0\" simulationFunctionName=\"product\" simulationFunctionType=\"C_OR_FORTRAN\" style=\"PRODUCT\">\n  <ScilabString as=\"exprs\" height=\"2\" width=\"1\">\n    <data line=\"0\" column=\"0\" value=\"[1;-1]\"/>\n    <data line=\"1\" column=\"0\" value=\"1\"/>\n  </ScilabString>\n  <ScilabDouble as=\"realParameters\" height=\"1\" width=\"1\">\n    <data line=\"0\" column=\"0\" realPart=\"0.0\"/>\n  </ScilabDouble>\n  <ScilabInteger as=\"integerParameters\" height=\"1\" width=\"2\" intPrecision=\"sci_int32\">\n    <data line=\"0\" column=\"0\" value=\"1\"/>\n    <data line=\"0\" column=\"1\" value=\"-1\"/>\n  </ScilabInteger>\n  <mxGeometry as=\"geometry\" x=\"100.0\" y=\"100.0\" width=\"40.0\" height=\"60.0\"/>\n</Product>",
  "anomalies": [
    "Uses 'Product' tag instead of 'BasicBlock'",
    "exprs[0] encodes [multiply;divide] pattern",
    "Height is 60 (taller than standard 40)",
    "integerParameters encodes the sign pattern",
    "Supports both multiplication and division"
  ],
  "criticalRules": [
    "exprs[0] signs: 1=multiply, -1=divide (e.g., [1;-1] = first/second)",
