    "Standard PRODUCT symbol shown inside block",
    "Height 60 to accommodate multiple ports"
  ],
  "commonUses": [
    "Multiplication of two signals",
    "Division (output = input1/input2)",
    "Squaring signals ([1;1] with same input)",
    "Inverse computation ([-1] with single input)"
